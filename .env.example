# Copy this file to .env and fill in your RapidAPI credentials.
# Never commit .env or real API keys to git.

RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=restcountries-v1.p.rapidapi.com
RAPIDAPI_URL=https://restcountries-v1.p.rapidapi.com/all
RAPIDAPI_COUNTRY_PARAM=country
RAPIDAPI_MODE=all_filter
